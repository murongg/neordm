{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NeoRDM",
  "version": "../package.json",
  "identifier": "com.murong.neordm",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/murongg/neordm/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDRjNEODgzNzg3N0M5MUMKUldRY3lYZDRnOWp6SE9mY0FTd0prZDhWd2crNFU2a1lEQm45ZlVpTENWeXhLck1pejdtNkducmkK"
    }
  }
}
